{
  "name": "@agentableui/cli",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.0",
  "description": "CLI tools for AgentableUI — generate manifests, validate configs, manage keys",
  "type": "module",
  "bin": {
    "agentableui": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentableui/core": "workspace:*",
    "commander": "^13.0.0",
    "jiti": "^2.0.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
